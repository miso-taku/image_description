# Backend configuration example.
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Required for real image descriptions (tests do not need it).
OPENAI_API_KEY=

# Vision-capable OpenAI model. gpt-4.1-mini balances quality and cost.
OPENAI_MODEL=gpt-4.1-mini

# Seconds before an OpenAI request times out.
OPENAI_TIMEOUT_SECONDS=60

# Maximum accepted image size in bytes (default 10 MB).
MAX_IMAGE_BYTES=10485760

# Comma-separated list of allowed CORS origins.
CORS_ALLOW_ORIGINS=http://localhost:3000

# Local rate limiting.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Meta
ENVIRONMENT=development
APP_VERSION=0.1.0
